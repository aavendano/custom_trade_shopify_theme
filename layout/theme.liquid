<!doctype html>
<html class="js" lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="theme-color" content="">

    {% render 'meta-tags' %}
    {% render 'global_favicon_renderer' %}

    {%- comment -%} Load deferred scripts {%- endcomment -%}
    {% render '_global-scripts-defer' %}

    {{ content_for_header }}
    {%- comment -%}
      Load storefront web components loader
      {% render 'storefront-web-components-loader' %}
    {%- endcomment -%}

    {%- unless settings.type_header_font.system? and settings.type_body_font.system? -%}
      <link rel="preconnect" href="https://fonts.shopifycdn.com" crossorigin>
    {%- endunless -%}

    {%- liquid
      assign body_font_bold = settings.type_body_font | font_modify: 'weight', 'bold'
      assign body_font_italic = settings.type_body_font | font_modify: 'style', 'italic'
      assign body_font_bold_italic = body_font_bold | font_modify: 'style', 'italic'
    %}

    {%- comment -%}
      Critical inline CSS for font loading and Alpine.js FOUC prevention
      All other CSS variables are now handled by the Bulma framework via
      src/bulma/sass/utilities/_shopify-variables.scss and
      src/bulma/sass/custom/_shopify-runtime.scss
    {%- endcomment -%}
    {% style %}
      {{ settings.type_body_font | font_face: font_display: 'swap' }}
      {{ body_font_bold | font_face: font_display: 'swap' }}
      {{ body_font_italic | font_face: font_display: 'swap' }}
      {{ body_font_bold_italic | font_face: font_display: 'swap' }}
      {{ settings.type_header_font | font_face: font_display: 'swap' }}

      {%- comment -%}
        Alpine.js x-cloak directive to prevent flash of unstyled content (FOUC)
        Elements with x-cloak will be hidden until Alpine.js initializes
      {%- endcomment -%}
      [x-cloak] {
        display: none !important;
      }
    {% endstyle %}

    {%- comment -%}
      MIGRATION NOTE: During the Bulma migration, we need to load both base.css
      and Bulma CSS to ensure Dawn components (header, icons, etc.) still work
      while we gradually migrate to Bulma. Once all components are migrated,
      base.css can be safely removed.
    {%- endcomment -%}
    {{ 'base.css' | asset_url | stylesheet_tag }}
    {{ 'font-loading.css' | asset_url | stylesheet_tag }}

    {% comment %}
      <link rel="stylesheet" href="{{ 'component-cart-items.css' | asset_url }}" media="print" onload="this.media='all'">
    {% endcomment %}

    {%- comment -%} Preload fonts for better performance {%- endcomment -%}
    {%- unless settings.type_body_font.system? -%}
      {% comment %}theme-check-disable AssetPreload{% endcomment %}
      <link rel="preload" as="font" href="{{ settings.type_body_font | font_url }}" type="font/woff2" crossorigin>
      {% comment %}theme-check-enable AssetPreload{% endcomment %}
    {%- endunless -%}
    {%- unless settings.type_header_font.system? -%}
      {% comment %}theme-check-disable AssetPreload{% endcomment %}
      <link rel="preload" as="font" href="{{ settings.type_header_font | font_url }}" type="font/woff2" crossorigin>
      {% comment %}theme-check-enable AssetPreload{% endcomment %}
    {%- endunless -%}

    {%- if localization.available_countries.size > 1 or localization.available_languages.size > 1 -%}
      {{ 'component-localization-form.css' | asset_url | stylesheet_tag: preload: true }}
      <script src="{{ 'localization-form.js' | asset_url }}" defer="defer"></script>
    {%- endif -%}

    {%- if settings.predictive_search_enabled -%}
      <link
        rel="stylesheet"
        href="{{ 'component-predictive-search.css' | asset_url }}"
        media="print"
        onload="this.media='all'"
      >
    {%- endif -%}

    {% liquid
      assign use_full_css = false

      # Detectar tema de desarrollo o no publicado
      if theme.role == 'development' or theme.role == 'unpublished'
        assign use_full_css = true
      endif

      # Detectar editor de temas (Liquid)
      if request.design_mode
        assign use_full_css = true
      endif

      # Override manual (opcional)
      if settings.force_full_css
        assign use_full_css = true
      endif
    %}
    <!-- CUSTOM  CSS -->
    <!-- BULMA -->

    {% if use_full_css %}
      {{ 'a-bulma-full.css' | asset_url | stylesheet_tag }}
      <script>
        console.log('####### Using Full Bulma CSS #######');
      </script>
    {% else %}
      {{ 'a-bulma-purged.css' | asset_url | stylesheet_tag }}
    {% endif %}

    {{ 'a-plt-custom-style.css' | asset_url | stylesheet_tag }}

    <script src="{{ 'cart-api.js' | asset_url }}" defer></script>
    <script src="{{ 'cart-store.js' | asset_url }}" defer="defer"></script>
    <script src="{{ 'cart-fragment.js' | asset_url }}" defer="defer"></script>
    <script src="{{ 'megamenu-store.js' | asset_url }}" defer="defer"></script>
    {% comment %}
      theme-check-disable AssetPreload
      <script src="{{ 'alpine-product-card.js' | asset_url }}" defer></script>
    {% endcomment %}
    <script defer src="{{ 'alpine-bundle.js' | asset_url }}"></script>

    {% liquid
      assign storefront_public_token = settings.storefront_public_access_token | default: '3e26b62b29d0391ee6599156c04e33fb'
    %}

    <shopify-store
      store-domain="https://{{ shop.permanent_domain }}"
      country="{{ localization.country.iso_code }}"
      language="{{ localization.language.iso_code }}"
      public-access-token="{{ storefront_public_token }}"
    ></shopify-store>
  </head>

  <body class="gradient{% if settings.animations_hover_elements != 'none' %} animate--hover-{{ settings.animations_hover_elements }}{% endif %}">
    <a class="skip-to-content-link button visually-hidden" href="#MainContent">
      {{ 'accessibility.skip_to_text' | t }}
    </a>

    {% sections 'header-group' %}

    <main id="MainContent" class="content-for-layout focus-none b-has-background-grey-light" role="main" tabindex="-1">
      <div class="b-container b-mx-auto">
        {{ content_for_layout }}
      </div>
    </main>

    {% sections 'footer-group' %}

    <ul hidden>
      <li id="a11y-refresh-page-message">{{ 'accessibility.refresh_page' | t }}</li>
      <li id="a11y-new-window-message">{{ 'accessibility.link_messages.new_window' | t }}</li>
    </ul>

    {%- if settings.predictive_search_enabled -%}
      <script src="{{ 'predictive-search.js' | asset_url }}" defer="defer"></script>
    {%- endif -%}

    <script>
      window.STORAGE_KEY = `{{ shop.permanent_domain | handle }}-recently-viewed`;

      // SHOPIFY DESIGN MODE DETECTION
      if (Shopify.designMode) {
        document.documentElement.classList.add('shopify-design-mode');
      }
    </script>
    {% render 'global_seo_snippets' %}
  </body>
</html>
