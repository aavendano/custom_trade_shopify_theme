<div class="b-card-display-item">
  {% comment %}
    This block is rendered by the b-carousel wrapper or the parent section.
  {% endcomment %}
</div>

{% schema %}
{
  "name": "Collections Grid Card",
  "settings": [
    {
      "type": "text",
      "id": "collections_card_title",
      "label": "Card title",
      "info": "Leave empty to use main collection title"
    },
    {
      "type": "collection",
      "id": "main_collection",
      "label": "Main collection (for title/URL)",
      "info": "Optional - used for title and default URL"
    },
    {
      "type": "collection_list",
      "id": "collection_list",
      "label": "Collections",
      "limit": 12
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "CTA URL",
      "info": "Leave empty to use main collection URL"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "CTA button text",
      "default": "Explore All"
    },
    {
      "type": "checkbox",
      "id": "priority",
      "label": "Preload images",
      "default": false
    }
  ],
  "presets": [
    {
      "name": "Collections Grid Card"
    }
  ]
}
{% endschema %}
