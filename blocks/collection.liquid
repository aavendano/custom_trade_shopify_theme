<div class="b-card-display-item">
  {% comment %}
    This block is rendered by the b-carousel wrapper or the parent section.
  {% endcomment %}
</div>

{% schema %}
{
  "name": "Collection Card",
  "settings": [
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "checkbox",
      "id": "show_description",
      "label": "Show description",
      "default": true
    },
    {
      "type": "range",
      "id": "truncatewords",
      "min": 10,
      "max": 50,
      "step": 5,
      "label": "Description word limit",
      "default": 20
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Custom CTA URL",
      "info": "Leave empty to use collection URL"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "CTA button text",
      "default": "Shop Now"
    },
    {
      "type": "checkbox",
      "id": "priority",
      "label": "Preload image",
      "default": false
    }
  ],
  "presets": [
    {
      "name": "Collection Card"
    }
  ]
}
{% endschema %}
