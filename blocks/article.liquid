<div class="b-card-display-item">
  {% comment %}
    This block is rendered by the b-carousel wrapper or the parent section.
    Its content structure is currently handled there.
  {% endcomment %}
</div>

{% schema %}
{
  "name": "Article Card",
  "settings": [
    {
      "type": "article",
      "id": "article",
      "label": "Article"
    },
    {
      "type": "checkbox",
      "id": "priority",
      "label": "Preload image",
      "default": false,
      "info": "Enable for first slide only"
    }
  ],
  "presets": [
    {
      "name": "Article Card"
    }
  ]
}
{% endschema %}
