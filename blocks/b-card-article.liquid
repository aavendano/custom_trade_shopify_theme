<div
  class="b-card b-has-background-info-light"
  {{ block.shopify_attributes }}
>
  <header class="b-card-header">
    <p class="b-card-header-title b-is-capitalized b-title b-is-5">
      {{ block.settings.article.title }}
    </p>
  </header>
  {% if block.settings.article.image %}
    <div class="b-card-image">
      <figure class="b-image b-is-square">
        {{
          block.settings.article.image
          | image_url: width: 400
          | image_tag:
            widths: '50, 100, 150, 200, 250, 300, 350, 400, 450, 500, 550, 600',
            loading: 'lazy',
            preload: block.settings.priority
        }}
      </figure>
    </div>
  {% endif %}
  <div class="b-card-content b-p-2">
    <div class="b-content">
      {{
        block.settings.article.excerpt
        | default: block.settings.article.content
        | strip_html
        | truncatewords: 20, '...'
      }}
    </div>
  </div>
  <footer class="b-card-footer">
    <a
      href="{{ block.settings.article.url }}"
      class="b-card-footer-item b-button b-is-info b-is-outlined b-is-light b-is-size-5"
    >
      {{ 'general.read_more' | t }}
    </a>
  </footer>
</div>

{% schema %}
{
  "name": "b-Card Article",
  "settings": [
    {
      "type": "article",
      "id": "article",
      "label": "Article"
    },
    {
      "type": "checkbox",
      "id": "priority",
      "label": "Preload image",
      "default": false
    }
  ],
  "presets": [
    {
      "name": "b-Card Article",
      "category": "b-Blocks"
    }
  ]
}
{% endschema %}
