{% doc %}
  @prompt
    Create a Liquid theme block that reads a collection metafield of type blog article (blog post reference). If the metafield exists and is not null, render the article content (title, image, excerpt or body, and a read more link) inside the collection template. If the metafield is null or does not exist, render nothing — no empty HTML elements or wrapper divs. The block should be clean, semantic, and conditionally output zero HTML when the metafield is absent., que se asocie al metafield custom.content_article
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}
{% assign article_metafield = collection.metafields.custom.content_article %}

{% if article_metafield != blank %}
  {% style %}
    .ai-collection-article-{{ ai_gen_id }} {
      display: block;
      width: {{ block.settings.desktop_width_percent }}%;
      max-width: 100%;
      margin: 0 auto;
    }

    .ai-collection-article__wrapper-{{ ai_gen_id }} {
      background-color: {{ block.settings.background_color }};
      border-radius: {{ block.settings.border_radius }}px;
      padding: {{ block.settings.padding }}px;
      box-shadow: 0 {{ block.settings.shadow_vertical }}px {{ block.settings.shadow_blur }}px rgba(0, 0, 0, {{ block.settings.shadow_opacity }});
    }

    .ai-collection-article__image-wrapper-{{ ai_gen_id }} {
      width: 100%;
      margin-bottom: {{ block.settings.spacing }}px;
      overflow: hidden;
      border-radius: {{ block.settings.image_radius }}px;
    }

    .ai-collection-article__image-{{ ai_gen_id }} {
      width: 100%;
      height: auto;
      display: block;
      object-fit: cover;
    }

    .ai-collection-article__content-{{ ai_gen_id }} {
      display: flex;
      flex-direction: column;
      gap: {{ block.settings.spacing }}px;
    }

    .ai-collection-article__title-{{ ai_gen_id }} {
      margin: 0;
      font-size: {{ block.settings.title_size }}px;
      color: {{ block.settings.text_color }};
      line-height: 1.3;
    }

    .ai-collection-article__excerpt-{{ ai_gen_id }} {
      margin: 0;
      font-size: {{ block.settings.text_size }}px;
      color: {{ block.settings.text_color }};
      line-height: 1.6;
    }

    .ai-collection-article__link-{{ ai_gen_id }} {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
      background-color: {{ block.settings.button_bg_color }};
      color: {{ block.settings.button_text_color }};
      text-decoration: none;
      border-radius: {{ block.settings.button_radius }}px;
      font-size: {{ block.settings.button_text_size }}px;
      font-weight: 600;
      transition: background-color 0.3s ease;
      align-self: flex-start;
    }

    .ai-collection-article__link-{{ ai_gen_id }}:hover {
      background-color: {{ block.settings.button_hover_bg_color }};
    }

    .ai-collection-article__link-icon-{{ ai_gen_id }} {
      width: 16px;
      height: 16px;
      stroke: currentColor;
    }

    @media screen and (max-width: 749px) {
      .ai-collection-article__wrapper-{{ ai_gen_id }} {
        padding: {{ block.settings.padding | times: 0.7 }}px;
      }

      .ai-collection-article__title-{{ ai_gen_id }} {
        font-size: {{ block.settings.title_size | times: 0.8 }}px;
      }

      .ai-collection-article__excerpt-{{ ai_gen_id }} {
        font-size: {{ block.settings.text_size | times: 0.9 }}px;
      }
    }
  {% endstyle %}

  <div class="ai-collection-article-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
    <article class="ai-collection-article__wrapper-{{ ai_gen_id }}">
      {% if block.settings.show_image and article_metafield.image %}
        <div class="ai-collection-article__image-wrapper-{{ ai_gen_id }}">
          <img
            src="{{ article_metafield.image | image_url: width: 1200 }}"
            alt="{{ article_metafield.image.alt | escape }}"
            width="{{ article_metafield.image.width }}"
            height="{{ article_metafield.image.height }}"
            loading="lazy"
            class="ai-collection-article__image-{{ ai_gen_id }}"
          >
        </div>
      {% endif %}

      <div class="ai-collection-article__content-{{ ai_gen_id }}">
        {% if block.settings.show_title %}
          <h2 class="ai-collection-article__title-{{ ai_gen_id }}">
            {{ article_metafield.title }}
          </h2>
        {% endif %}

        {% if block.settings.show_excerpt %}
          <div class="ai-collection-article__excerpt-{{ ai_gen_id }}">
            {% if article_metafield.excerpt != blank %}
              {{ article_metafield.excerpt | strip_html | truncate: block.settings.excerpt_length }}
            {% else %}
              {{ article_metafield.content | strip_html | truncate: block.settings.excerpt_length }}
            {% endif %}
          </div>
        {% endif %}

        {% if block.settings.show_link %}
          <a
            href="{{ article_metafield.url }}"
            class="ai-collection-article__link-{{ ai_gen_id }}"
          >
            {{ block.settings.link_text }}
            <svg
              class="ai-collection-article__link-icon-{{ ai_gen_id }}"
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="none"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <line x1="5" y1="12" x2="19" y2="12"></line>
              <polyline points="12 5 19 12 12 19"></polyline>
            </svg>
          </a>
        {% endif %}
      </div>
    </article>
  </div>
{% endif %}

{% schema %}
{
  "name": "Collection article",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "paragraph",
      "content": "This block displays a blog article from the collection's 'content_article' metafield. If the metafield is empty, nothing will be rendered."
    },
    {
      "type": "checkbox",
      "id": "show_image",
      "label": "Show image",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_title",
      "label": "Show title",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_excerpt",
      "label": "Show excerpt",
      "default": true
    },
    {
      "type": "range",
      "id": "excerpt_length",
      "label": "Excerpt length",
      "min": 50,
      "max": 500,
      "step": 10,
      "default": 200
    },
    {
      "type": "checkbox",
      "id": "show_link",
      "label": "Show read more link",
      "default": true
    },
    {
      "type": "text",
      "id": "link_text",
      "label": "Link text",
      "default": "Read more"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "range",
      "id": "padding",
      "label": "Padding",
      "min": 0,
      "max": 60,
      "step": 4,
      "unit": "px",
      "default": 32
    },
    {
      "type": "range",
      "id": "spacing",
      "label": "Content spacing",
      "min": 8,
      "max": 40,
      "step": 4,
      "unit": "px",
      "default": 16
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#231f20"
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Border radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 8
    },
    {
      "type": "range",
      "id": "image_radius",
      "label": "Image radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 8
    },
    {
      "type": "range",
      "id": "shadow_opacity",
      "label": "Shadow opacity",
      "min": 0,
      "max": 1,
      "step": 0.1,
      "default": 0.1
    },
    {
      "type": "range",
      "id": "shadow_vertical",
      "label": "Shadow vertical offset",
      "min": 0,
      "max": 20,
      "step": 2,
      "unit": "px",
      "default": 4
    },
    {
      "type": "range",
      "id": "shadow_blur",
      "label": "Shadow blur",
      "min": 0,
      "max": 40,
      "step": 5,
      "unit": "px",
      "default": 15
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "title_size",
      "label": "Title size",
      "min": 16,
      "max": 48,
      "step": 2,
      "unit": "px",
      "default": 28
    },
    {
      "type": "range",
      "id": "text_size",
      "label": "Text size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "header",
      "content": "Button"
    },
    {
      "type": "color",
      "id": "button_bg_color",
      "label": "Background",
      "default": "#533278"
    },
    {
      "type": "color",
      "id": "button_hover_bg_color",
      "label": "Hover background",
      "default": "#f4436c"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Text",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "button_text_size",
      "label": "Text size",
      "min": 12,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "range",
      "id": "button_padding_vertical",
      "label": "Vertical padding",
      "min": 8,
      "max": 24,
      "step": 2,
      "unit": "px",
      "default": 12
    },
    {
      "type": "range",
      "id": "button_padding_horizontal",
      "label": "Horizontal padding",
      "min": 16,
      "max": 48,
      "step": 4,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "button_radius",
      "label": "Border radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 22
    }
  ],
  "presets": [
    {
      "name": "Collection article"
    }
  ]
}
{% endschema %}
