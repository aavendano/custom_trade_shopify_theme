{% doc %}
  @prompt
    Ayúdame a crear un bloque Liquid que tome un  metafield custom.content_article , y lo renderice en el template. Si el collection metafield no existe o es nulo no se inserta nada en el html
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% if collection.metafields.custom.content_article != blank %}
  {% style %}
    .ai-collection-article-{{ ai_gen_id }} {
      width: {{ block.settings.desktop_width_percent }}%;
      max-width: 100%;
      display: block;
    }

    .ai-collection-article__container-{{ ai_gen_id }} {
      background-color: {{ block.settings.background_color }};
      padding: {{ block.settings.padding }}px;
      border-radius: {{ block.settings.border_radius }}px;
    }

    .ai-collection-article__content-{{ ai_gen_id }} {
      color: {{ block.settings.text_color }};
      font-size: {{ block.settings.font_size }}px;
      line-height: 1.6;
    }

    .ai-collection-article__content-{{ ai_gen_id }} h1,
    .ai-collection-article__content-{{ ai_gen_id }} h2,
    .ai-collection-article__content-{{ ai_gen_id }} h3,
    .ai-collection-article__content-{{ ai_gen_id }} h4,
    .ai-collection-article__content-{{ ai_gen_id }} h5,
    .ai-collection-article__content-{{ ai_gen_id }} h6 {
      color: {{ block.settings.heading_color }};
      margin-top: 1.5em;
      margin-bottom: 0.5em;
    }

    .ai-collection-article__content-{{ ai_gen_id }} h1:first-child,
    .ai-collection-article__content-{{ ai_gen_id }} h2:first-child,
    .ai-collection-article__content-{{ ai_gen_id }} h3:first-child,
    .ai-collection-article__content-{{ ai_gen_id }} h4:first-child,
    .ai-collection-article__content-{{ ai_gen_id }} h5:first-child,
    .ai-collection-article__content-{{ ai_gen_id }} h6:first-child {
      margin-top: 0;
    }

    .ai-collection-article__content-{{ ai_gen_id }} p {
      margin-bottom: 1em;
    }

    .ai-collection-article__content-{{ ai_gen_id }} a {
      color: {{ block.settings.link_color }};
      text-decoration: underline;
    }

    .ai-collection-article__content-{{ ai_gen_id }} a:hover {
      color: {{ block.settings.link_hover_color }};
    }

    .ai-collection-article__content-{{ ai_gen_id }} ul,
    .ai-collection-article__content-{{ ai_gen_id }} ol {
      margin-bottom: 1em;
      padding-left: 1.5em;
    }

    .ai-collection-article__content-{{ ai_gen_id }} img {
      max-width: 100%;
      height: auto;
      border-radius: {{ block.settings.image_border_radius }}px;
    }

    @media screen and (max-width: 749px) {
      .ai-collection-article__container-{{ ai_gen_id }} {
        padding: {{ block.settings.padding | times: 0.6 }}px;
      }

      .ai-collection-article__content-{{ ai_gen_id }} {
        font-size: {{ block.settings.font_size | times: 0.9 }}px;
      }
    }
  {% endstyle %}

  <div class="ai-collection-article-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
    <div class="ai-collection-article__container-{{ ai_gen_id }}">
      <div class="ai-collection-article__content-{{ ai_gen_id }}">
        {{ collection.metafields.custom.content_article }}
      </div>
    </div>
  </div>
{% endif %}

{% schema %}
{
  "name": "Collection article",
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "range",
      "id": "padding",
      "label": "Padding",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Border radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 8
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#231f20"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Headings",
      "default": "#231f20"
    },
    {
      "type": "color",
      "id": "link_color",
      "label": "Links",
      "default": "#533278"
    },
    {
      "type": "color",
      "id": "link_hover_color",
      "label": "Links hover",
      "default": "#f4436c"
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "font_size",
      "label": "Font size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "image_border_radius",
      "label": "Image border radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 8
    }
  ],
  "presets": [
    {
      "name": "Collection article"
    }
  ]
}
{% endschema %}
