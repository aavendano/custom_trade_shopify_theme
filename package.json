{
  "name": "custom_trade_shopify_theme",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "build:bulma": "sass src/bulma/bulma.scss assets/a-bulma-full.css",
    "prepurgecss": "node src/purge/extract-b-safelist.js",
    "purgecss": "npx postcss assets/a-bulma-full.css -o assets/a-bulma-purged.css --config src --no-map",
    "prepurgecss:base": "node src/purge/extract-base-safelist.js",
    "purgecss:base": "npx postcss assets/base.css -o assets/base-purged.css --config src/postcss.config.base.cjs --no-map",
    "build:base": "npm run prepurgecss:base && npm run purgecss:base",
    "build:alpine": "esbuild src/alpine-bundle.js --bundle --outfile=assets/alpine-bundle.js",
    "start": "npm run build:bulma -- --watch",
    "build": "npm run build:bulma && npm run prepurgecss && npm run purgecss && npm run build:alpine && npm run build:base",
    "test": "node src/tests/validate-foundation.js",
    "test:validate": "node src/tests/validate-foundation.js",
    "test:purge": "node src/purge/validate-purged-css.js",
    "validate": "npm run test:validate && npm run test:purge",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aavendano/custom_trade_shopify_theme.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/aavendano/custom_trade_shopify_theme/issues"
  },
  "homepage": "https://github.com/aavendano/custom_trade_shopify_theme#readme",
  "dependencies": {
    "@alpinejs/collapse": "^3.15.2",
    "@alpinejs/intersect": "^3.15.1",
    "@imacrayon/alpine-ajax": "^0.12.6",
    "@playwright/test": "^1.56.1",
    "alpinejs": "^3.15.1",
    "bulma": "^1.0.4",
    "playwright": "^1.56.1",
    "sass": "^1.93.3"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^4.1.3",
    "@fullhuman/postcss-purgecss": "^7.0.2",
    "@shopify/prettier-plugin-liquid": "^1.10.0",
    "@storybook/addon-a11y": "^10.1.6",
    "@storybook/addon-docs": "^10.1.6",
    "@storybook/addon-vitest": "^10.1.6",
    "@storybook/html-vite": "^10.1.6",
    "@vitest/browser-playwright": "^4.0.15",
    "@vitest/coverage-v8": "^4.0.15",
    "cssnano": "^7.0.6",
    "esbuild": "^0.25.12",
    "glob": "^11.0.3",
    "postcss": "^8.5.6",
    "postcss-cli": "^11.0.1",
    "prettier": "^3.7.4",
    "purgecss": "^7.0.2",
    "rimraf": "^6.0.1",
    "sass": "^1.86.3",
    "storybook": "^10.1.6",
    "through2": "^4.0.2",
    "vitest": "^4.0.15"
  }
}