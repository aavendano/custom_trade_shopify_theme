{% comment %}
  Facets Drawer — Bulma-first version
  Renders filtering & sorting inside a Bulma modal acting as a sliding drawer.
  Accepts:
    - results: {Object}
    - enable_filtering: {Boolean}
    - enable_sorting: {Boolean}
{% endcomment %}

{%- liquid
  assign sort_by = results.sort_by | default: results.default_sort_by

  if results.url
    assign results_url = results.url
    assign form_action = results.url
  else
    assign terms = results.terms | escape
    assign results_url = '?q=' | append: terms | append: '&options%5Bprefix%5D=last&sort_by=' | append: sort_by
    assign form_action = routes.search_url
  endif
-%}

<style>
  /* =========================================================
     Drawer: convierte el modal de Bulma en un panel lateral
     ========================================================= */

  .b-modal {
    display: flex;
    align-items: flex-start;
    justify-content: flex-start;
  }

  .b-modal .b-modal-content {
    width: 100%;
    max-width: 420px;
    height: 100vh;
    overflow-y: auto;
    background: white;
    transform: translateX(-100%);
    transition: transform 0.3s ease;
    box-shadow: 5px 0 15px rgba(0, 0, 0, 0.1);
  }

  .b-modal.b-is-active .b-modal-content {
    transform: translateX(0);
  }

  @media (min-width: 1024px) {
    .b-modal .b-modal-content {
      max-width: 25vw;
    }
  }
</style>

<div x-data="{ drawerOpen: false }" class="facets-wrapper">
  <div class="b-level b-is-sticky b-top-4 b-px-4 b-has-background-white b-border-bottom-light">
    <div class="b-level-left">
      <button
        type="button"
        class="b-button b-is-primary b-is-rounded"
        @click="drawerOpen = true"
      >
        <span class="b-icon">
          {{ 'icon-filter.svg' | inline_asset_content }}
        </span>
        <span>{{ 'products.facets.filter_and_sort' | t }}</span>
      </button>
    </div>

    <div class="b-level-right">
      <p class="b-is-size-7">
        {% if results.results_count %}
          {{ 'templates.search.results_with_count' | t: terms: results.terms, count: results.results_count }}
        {% else %}
          {{ 'products.facets.product_count_simple' | t: count: results.products_count }}
        {% endif %}
      </p>
    </div>
  </div>

  <div
    class="b-modal"
    :class="{ 'b-is-active': drawerOpen }"
    @keydown.escape.window="drawerOpen = false"
  >
    <div class="b-modal-background" @click="drawerOpen = false"></div>

    <div class="b-modal-content">
      <form
        id="FacetFiltersForm"
        action="{{ form_action }}"
        x-target="product-grid-container"
        x-on:input.debounce.800ms="$el.requestSubmit()"
        class="b-modal-card b-is-flex b-is-flex-direction-column b-h-full"
      >
        <header class="b-modal-card-head b-is-radiusless">
          <p class="b-modal-card-title">
            {{ 'products.facets.filter_and_sort' | t }}
          </p>
          <button type="button" class="b-delete" @click="drawerOpen = false"></button>
        </header>

        <section class="b-modal-card-body b-is-flex-grow-1">
          {% if results.terms %}
            <input type="hidden" name="q" value="{{ results.terms | escape }}">
            <input type="hidden" name="options[prefix]" value="last">
          {% endif %}

          {% if enable_sorting %}
            <div class="b-field b-mb-5">
              <label class="b-label" for="SortBy">{{ 'products.facets.sort_by_label' | t }}</label>

              <div class="b-control">
                <div class="b-select b-is-fullwidth">
                  <select name="sort_by" id="SortBy">
                    {% for option in results.sort_options %}
                      <option
                        value="{{ option.value | escape }}"
                        {% if option.value == sort_by %}
                          selected
                        {% endif %}
                      >
                        {{ option.name | escape }}
                      </option>
                    {% endfor %}
                  </select>
                </div>
              </div>
            </div>

            <hr class="b-dropdown-divider">
          {% endif %}

          {% if enable_filtering %}
            {% for filter in results.filters %}
              <div class="b-mb-4" x-data="{ open: true }">
                <button
                  type="button"
                  class="b-button b-is-white b-is-fullwidth b-is-justify-content-space-between"
                  @click="open = !open"
                >
                  <span class="b-has-text-weight-bold">
                    {{ filter.label | escape }}
                  </span>

                  <span class="b-icon b-is-small">
                    {{ 'icon-caret.svg' | inline_asset_content }}
                  </span>
                </button>

                <div x-show="open" x-collapse>
                  <div class="b-mt-2 b-pl-4">
                    {% case filter.type %}
                      {% when 'boolean', 'list' %}
                        {% for value in filter.values %}
                          <div class="b-field">
                            <label class="b-checkbox">
                              <input
                                type="checkbox"
                                name="{{ value.param_name }}"
                                value="{{ value.value }}"
                                {% if value.active %}
                                  checked
                                {% endif %}
                                {% if value.count == 0 and value.active == false %}
                                  disabled
                                {% endif %}
                              >
                              {{ value.label | escape }} ({{ value.count }})
                            </label>
                          </div>
                        {% endfor %}

                      {% when 'price_range' %}
                        <div class="facets__price">
                          {% render 'price-facet', filter: filter, id_prefix: 'Filter-' %}
                        </div>
                    {% endcase %}
                  </div>
                </div>
              </div>

              <hr class="b-dropdown-divider">
            {% endfor %}
          {% endif %}
        </section>

        <footer class="b-modal-card-foot b-is-radiusless">
          <a href="{{ results_url }}" class="b-button" x-target="product-grid-container">
            {{ 'products.facets.clear_all' | t }}
          </a>

          <button type="button" class="b-button b-is-primary" @click="drawerOpen = false">
            {{ 'products.facets.apply' | t }}
          </button>
        </footer>
      </form>
    </div>
  </div>
</div>

<script src="{{ 'show-more.js' | asset_url }}" defer></script>
