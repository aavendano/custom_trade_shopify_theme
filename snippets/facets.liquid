{% comment %}
  Renders facets (filtering and sorting) as a unified drawer.
  Accepts:
  - results: {Object} Collection or Search object
  - enable_filtering: {Boolean}
  - enable_sorting: {Boolean}
{% endcomment %}

{%- liquid
  assign sort_by = results.sort_by | default: results.default_sort_by
  if results.url
    assign results_url = results.url
  else
    assign terms = results.terms | escape
    assign results_url = '?q=' | append: terms | append: '&options%5Bprefix%5D=last&sort_by=' | append: sort_by
    assign form_action = routes.search_url
  endif
  if results.url
    assign form_action = results.url
  endif
-%}

<style>
  .b-modal {
    display: none;
    align-items: flex-start; /* Align to top-left */
    justify-content: flex-start;
    overflow: hidden;
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    top: 0;
    z-index: 9999;
    pointer-events: none; /* Allow clicks to pass through wrapper if not active */
  }
  .b-modal.b-is-active {
    display: flex;
    pointer-events: auto;
  }
  .b-modal-background {
    background-color: rgba(10, 10, 10, 0.5); /* Lighter overlay */
    bottom: 0;
    left: 0;
    position: absolute;
    right: 0;
    top: 0;
  }
  .b-modal-content {
    margin: 0;
    max-height: none;
    overflow: auto;
    position: relative;
    width: 100%;
    height: 100%;
    background-color: #ffffff !important;
    box-shadow: 5px 0 15px rgba(0, 0, 0, 0.1); /* Add shadow for depth */
  }
  /* Sticky Trigger Button */
  .facets-sticky-trigger {
    position: sticky;
    top: 1rem; /* Adjust based on header height */
    z-index: 30;
    background: white; /* Ensure background so it covers content behind */
    padding: 1rem 0;
    margin-bottom: 0 !important; /* Override b-mb-4 to prevent gaps */
    border-bottom: 1px solid #f0f0f0;
  }
  .facets-trigger-button {
    background-color: #000000 !important; /* Force black background */
    color: #ffffff !important; /* Force white text */
    border: none;
    padding: 0.5rem 1rem;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .facets-trigger-button .b-icon {
    color: #ffffff !important;
  }
</style>

<div x-data="{ drawerOpen: false }" class="facets-wrapper">
  {% comment %} Trigger Button {% endcomment %}
  <div class="b-level facets-sticky-trigger b-px-4">
    <div class="b-level-left">
      <button
        type="button"
        class="b-button b-is-primary facets-trigger-button"
        @click="drawerOpen = true"
      >
        <span class="b-icon">
          {{- 'icon-filter.svg' | inline_asset_content -}}
        </span>
        <span>{{ 'products.facets.filter_and_sort' | t }}</span>
      </button>
    </div>
    <div class="b-level-right">
      <p class="b-is-size-7">
        {%- if results.results_count -%}
          {{ 'templates.search.results_with_count' | t: terms: results.terms, count: results.results_count }}
        {%- else -%}
          {{ 'products.facets.product_count_simple' | t: count: results.products_count }}
        {%- endif -%}
      </p>
    </div>
  </div>

  {% comment %} Drawer Overlay & Panel {% endcomment %}
  <div
    class="b-modal"
    :class="{ 'b-is-active': drawerOpen }"
    x-show="drawerOpen"
    style="display: none;"
    x-transition.opacity
    @keydown.escape.window="drawerOpen = false"
  >
    <div class="b-modal-background" @click="drawerOpen = false"></div>

    <div
      class="b-modal-content has-background-white"
      style="height: 100%; position: fixed; top: 0; left: 0; margin: 0; overflow-y: auto; transition: transform 0.3s ease-in-out; width: 100%; max-width: none; background-color: #ffffff !important; box-shadow: 5px 0 15px rgba(0,0,0,0.1);"
      :style="window.innerWidth >= 1024 ? 'width: 25vw; max-width: none;' : ''"
      x-show="drawerOpen"
      x-transition:enter="transition ease-out duration-300"
      x-transition:enter-start="transform -translate-x-full"
      x-transition:enter-end="transform translate-x-0"
      x-transition:leave="transition ease-in duration-300"
      x-transition:leave-start="transform translate-x-0"
      x-transition:leave-end="transform -translate-x-full"
    >
      <form
        id="FacetFiltersForm"
        action="{{ form_action }}"
        x-target="product-grid-container"
        x-on:input.debounce.800ms="$el.requestSubmit()"
        class="b-is-flex b-is-flex-direction-column b-h-full"
        style="height: 100%;"
      >
        {% comment %} Header {% endcomment %}
        <div class="b-modal-card-head b-is-radiusless">
          <p class="b-modal-card-title">{{ 'products.facets.filter_and_sort' | t }}</p>
          <button type="button" class="b-delete" aria-label="close" @click="drawerOpen = false"></button>
        </div>

        {% comment %} Body {% endcomment %}
        <div class="b-modal-card-body b-is-flex-grow-1">
          {%- if results.terms -%}
            <input type="hidden" name="q" value="{{ results.terms | escape }}">
            <input name="options[prefix]" type="hidden" value="last">
          {%- endif -%}

          {% comment %} Sorting {% endcomment %}
          {%- if enable_sorting -%}
            <div class="b-field b-mb-5">
              <label class="b-label" for="SortBy">{{ 'products.facets.sort_by_label' | t }}</label>
              <div class="b-control">
                <div class="b-select b-is-fullwidth">
                  <select name="sort_by" id="SortBy" aria-describedby="a11y-refresh-page-message">
                    {%- for option in results.sort_options -%}
                      <option
                        value="{{ option.value | escape }}"
                        {% if option.value == sort_by %}
                          selected="selected"
                        {% endif %}
                      >
                        {{ option.name | escape }}
                      </option>
                    {%- endfor -%}
                  </select>
                </div>
              </div>
            </div>
            <hr class="b-dropdown-divider">
          {%- endif -%}

          {% comment %} Filters {% endcomment %}
          {%- if enable_filtering -%}
            {%- for filter in results.filters -%}
              <div class="b-mb-4" x-data="{ open: true }">
                <button
                  type="button"
                  class="b-button b-is-white b-is-fullwidth b-is-justify-content-space-between"
                  @click="open = !open"
                >
                  <span class="b-has-text-weight-bold">{{ filter.label | escape }}</span>
                  <span class="b-icon b-is-small">
                    <i class="fas" :class="open ? 'fa-angle-up' : 'fa-angle-down'"></i>
                    {{- 'icon-caret.svg' | inline_asset_content -}}
                  </span>
                </button>

                <div x-show="open" x-collapse>
                  <div class="b-mt-2 b-pl-4">
                    {% case filter.type %}
                      {% when 'boolean', 'list' %}
                        {%- for value in filter.values -%}
                          <div class="b-field">
                            <div class="b-control">
                              <label class="b-checkbox">
                                <input
                                  type="checkbox"
                                  name="{{ value.param_name }}"
                                  value="{{ value.value }}"
                                  {% if value.active %}
                                    checked
                                  {% endif %}
                                  {% if value.count == 0 and value.active == false %}
                                    disabled
                                  {% endif %}
                                >
                                {{ value.label | escape }} ({{ value.count }})
                              </label>
                            </div>
                          </div>
                        {%- endfor -%}
                      {% when 'price_range' %}
                        <div class="facets__price" x-data="priceRange()">
                          {% render 'price-facet', filter: filter, id_prefix: 'Filter-' %}
                        </div>
                    {% endcase %}
                  </div>
                </div>
              </div>
              <hr class="b-dropdown-divider">
            {%- endfor -%}
          {%- endif -%}
        </div>

        {% comment %} Footer {% endcomment %}
        <div class="b-modal-card-foot b-is-radiusless">
          <a href="{{ results_url }}" class="b-button" x-target="product-grid-container">
            {{- 'products.facets.clear_all' | t -}}
          </a>
          <button type="button" class="b-button b-is-primary" @click="drawerOpen = false">
            {{ 'products.facets.apply' | t }}
          </button>
        </div>
      </form>
    </div>
  </div>
</div>

<script src="{{ 'show-more.js' | asset_url }}" defer="defer"></script>
