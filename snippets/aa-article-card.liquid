{% comment %}
  aa-article-card.liquid - Article Card Component
  Bulma-based article card for blog posts

  Parameters:
  - article: Article object (required)
  - blog: Blog object (required)
  - show_image: Boolean (default: true)
  - show_date: Boolean (default: true)
  - show_author: Boolean (default: false)
  - show_excerpt: Boolean (default: true)

  Created: 2025-12-28
{% endcomment %}

{%- liquid
  assign show_image = show_image | default: true
  assign show_date = show_date | default: true
  assign show_author = show_author | default: false
  assign show_excerpt = show_excerpt | default: true
-%}

<article class="b-card aa-article-card b-is-flex b-is-flex-direction-column b-has-radius">
  {%- if show_image and article.image -%}
    <div class="b-card-image">
      <figure class="b-image b-is-16by9">
        <a href="{{ article.url }}" aria-label="{{ article.title | escape }}">
          {{
            article.image
            | image_url: width: 800
            | image_tag:
              loading: 'lazy',
              widths: '400, 600, 800',
              sizes: '(min-width: 1024px) 33vw, (min-width: 768px) 50vw, 100vw',
              alt: article.image.alt
            | default: article.title
          }}
        </a>
      </figure>
    </div>
  {%- endif -%}

  <div class="b-card-content b-is-flex b-is-flex-direction-column b-is-flex-grow-1">
    {%- if show_date or show_author -%}
      <div class="b-is-flex b-is-flex-wrap-wrap b-is-align-items-center b-mb-3 b-is-size-7 b-has-text-grey">
        {%- if show_date -%}
          <time
            datetime="{{ article.published_at | date: '%Y-%m-%d' }}"
            class="b-is-flex b-is-align-items-center b-mr-4"
          >
            <svg
              class="b-mr-1"
              width="16"
              height="16"
              viewBox="0 0 16 16"
              fill="none"
              xmlns="http://www.w3.org/2000/svg"
            >
              <path d="M12.667 2.667h-1.334V2a.667.667 0 00-1.333 0v.667H6V2a.667.667 0 00-1.333 0v.667H3.333A1.333 1.333 0 002 4v9.333A1.333 1.333 0 003.333 14.667h9.334A1.333 1.333 0 0014 13.333V4a1.333 1.333 0 00-1.333-1.333zM12.667 13.333H3.333V6.667h9.334v6.666z" fill="currentColor"/>
            </svg>
            {{ article.published_at | date: format: 'month_day_year' }}
          </time>
        {%- endif -%}
        {%- if show_author and article.author -%}
          <span class="b-is-flex b-is-align-items-center">
            <svg
              class="b-mr-1"
              width="16"
              height="16"
              viewBox="0 0 16 16"
              fill="none"
              xmlns="http://www.w3.org/2000/svg"
            >
              <path d="M8 8a3.333 3.333 0 100-6.667A3.333 3.333 0 008 8zM8 9.333c-2.947 0-5.333 1.787-5.333 4v1.334h10.666v-1.334c0-2.213-2.386-4-5.333-4z" fill="currentColor"/>
            </svg>
            {{ article.author }}
          </span>
        {%- endif -%}
      </div>
    {%- endif -%}

    <h3 class="b-title b-is-4 b-mb-4">
      <a href="{{ article.url }}" class="aa-article-card__link">
        {{ article.title }}
      </a>
    </h3>

    {%- if show_excerpt and article.excerpt != blank -%}
      <div class="b-content b-mb-4 b-has-text-grey b-is-flex-grow-1">
        {{ article.excerpt | strip_html | truncatewords: 20 }}
      </div>
    {%- elsif show_excerpt and article.content != blank -%}
      <div class="b-content b-mb-4 b-has-text-grey b-is-flex-grow-1">
        {{ article.content | strip_html | truncatewords: 20 }}
      </div>
    {%- endif -%}

    <a href="{{ article.url }}" class="b-button b-is-text b-is-small b-is-flex b-is-align-items-center b-mt-auto">
      {{ 'blogs.article.read_more' | t }}
      <svg
        class="aa-article-card__arrow b-ml-1"
        width="16"
        height="16"
        viewBox="0 0 16 16"
        fill="none"
        xmlns="http://www.w3.org/2000/svg"
      >
        <path d="M6 12l4-4-4-4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </a>
  </div>
</article>
