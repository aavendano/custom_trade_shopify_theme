{%- for block in section.blocks -%}
  <div class="b-container">
    <div class="b-box">
      <div class="b-content">
        {% render block %}
      </div>
    </div>
  </div>
{%- endfor -%}

{% schema %}
{
  "name": "t:sections.apps.name",
  "tag": "section",
  "class": "b-section",
  "settings": [
    {
      "type": "checkbox",
      "id": "include_margins",
      "default": true,
      "label": "t:sections.apps.settings.include_margins.label"
    }
  ],
  "blocks": [
    {
      "type": "@app"
    }
  ],
  "presets": [
    {
      "name": "t:sections.apps.presets.name"
    }
  ]
}
{% endschema %}
