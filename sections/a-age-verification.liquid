{% stylesheet %}
.age-verify-overlay {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 9999;
}


.age-verify-overlay .b-modal-background {
  display: block !important;
}

.age-verify-overlay .b-modal-card {
  max-width: 500px;
  width: clamp(95%, 95%, 500px);
}

{% endstylesheet %}

{% comment %} sections/age-verification.liquid {% endcomment %}
<div x-data="ageVerification()" x-show="!verified" x-cloak class="age-verify-overlay">
  <div class="b-modal"
    :class="!verified ? 'b-is-active' : ''"
    >
      <div class="b-modal-background" x-show="!verified"></div>
    <div class="b-modal-card">
      <header class="b-modal-card-head">
        <p class="b-modal-card-title b-has-text-centered b-is-size-4">
          {{ section.settings.heading | default: 'Age Verification Required' }}
        </p>
      </header>
      <section class="b-modal-card-body b-has-text-centered">
        <div class="b-content">
          <p class="b-is-size-5">
            {{ section.settings.message | default: 'You must be 18 years or older to enter this site.' }}
          </p>
        </div>
      </section>
      <footer class="b-modal-card-foot b-is-justify-content-center">
        <button @click="confirmAge(true)" class="b-button b-is-primary b-is-medium b-has-text-white">
          {{ section.settings.confirm_text | default: 'I am 18 or older' }}
        </button>
        <button @click="confirmAge(false)" class="b-button b-is-light b-is-medium">
          {{ section.settings.decline_text | default: 'I am under 18' }}
        </button>
      </footer>
    </div>
  </div>
</div>

<script>
  function ageVerification() {
    return {
      verified: true,
      init() {
        // Esperar 3 segundos después de que la página cargue antes de verificar
        setTimeout(() => {
          this.verified = this.getCookie('age_verified') === 'true';
        }, {{ section.settings.delay }} * 1000);
      },
      confirmAge(isOfAge) {
        if (isOfAge) {
          this.setCookie('age_verified', 'true', 30);
          this.verified = true;
        } else {
          window.location.href = '{{ section.settings.decline_url | default: 'https://www.google.com' }}';
        }
      },
      setCookie(name, value, days) {
        const d = new Date();
        d.setTime(d.getTime() + (days * 24 * 60 * 60 * 1000));
        document.cookie = `${name}=${value};expires=${d.toUTCString()};path=/;SameSite=Strict`;
      },
      getCookie(name) {
        const match = document.cookie.match(new RegExp('(^| )' + name + '=([^;]+)'));
        return match ? match[2] : null;
      }
    }
  }
</script>

{% schema %}
{
  "name": "Age Verification",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Age Verification Required"
    },
    {
      "type": "number",
      "id": "delay",
      "label": "Delay (in seconds)",
      "default": 3
    },
    {
      "type": "textarea",
      "id": "message",
      "label": "Message",
      "default": "You must be 18 years or older to enter this site."
    },
    {
      "type": "text",
      "id": "confirm_text",
      "label": "Confirm button text",
      "default": "I am 18 or older"
    },
    {
      "type": "text",
      "id": "decline_text",
      "label": "Decline button text",
      "default": "I am under 18"
    },
    {
      "type": "url",
      "id": "decline_url",
      "label": "Redirect URL (if declined)",
      "default": "/"
    }
  ],
  "presets": [
    {
      "name": "Age Verification",
      "category": "AA Sections",

    }
  ]
}
{% endschema %}
