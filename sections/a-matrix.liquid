<style>
  .b-matrix .b-card {
    display: flex;
    flex-direction: column;
    height: 100%;
    justify-content: space-between;
  }

  .b-matrix .b-card .b-card-footer {
    margin-top: auto;
  }
</style>

<section class="b-section b-matrix">
  <div class="b-container">
    <div class="b-columns b-is-multiline b-is-3">
      {% content_for 'blocks' %}
    </div>
  </div>
</section>
{% schema %}
{
  "name": "a-matrix",
  "settings": [],
  "blocks": [
    {
      "type": "b-carousel"
    },
    {
      "type": "b-card-collection"
    },
    {
      "type": "b-card-article"
    },
    {
      "type": "b-card-products-grid"
    },
    {
      "type": "b-card-collections-grid"
    }
  ],

  "presets": [
    {
      "name": "a-matrix",
      "category": "a-Layout"
    }
  ]
}
{% endschema %}
