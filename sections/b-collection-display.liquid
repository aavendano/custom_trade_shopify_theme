<style>
  /* ==========================================================
   b-carousel — PlayLoveToys / b-bulma-alpine component
   Scroll-snap horizontal, mobile-first, ultra minimal
   ========================================================== */

  .b-carousel {
    display: flex;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    gap: 1rem;
    padding-bottom: 0.25rem; /* espacio para evitar corte del shadow */
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;

    /* Ocultar scrollbar en Chrome/Safari */
    &::-webkit-scrollbar {
      display: none;
    }

    /* Cards dentro del carrusel */
    > .b-carousel-item {
      flex: 0 0 auto;
      scroll-snap-align: start;

      /* Permite usar cualquier card interna sin romper layout */
      width: 100%;

      /* Clamp de anchura para mobile (estilo tienda) */
      max-width: 80vw;
    }
  }

  /* Desktop: cards ligeramente más grandes */
  @media screen and (min-width: 1024px) {
    .b-carousel > .b-carousel-item {
      max-width: 320px;
      width: 100%;
    }
  }

  /* Opcional: flechas flotantes */
  .b-carousel-nav {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 20;
    cursor: pointer;
  }

  .b-carousel-nav.is-left {
    left: 0.25rem;
  }

  .b-carousel-nav.is-right {
    right: 0.25rem;
  }
</style>

<section class="b-section">
  <div
    class="b-carousel"
    x-data
    x-ref="track"
  >
    <!-- LEFT -->
    <button
      class="b-carousel-nav is-left"
      @click="$refs.track.scrollBy({ left: -300, behavior: 'smooth' })"
    >
      ◀
    </button>

    <!-- RIGHT -->
    <button
      class="b-carousel-nav is-right"
      @click="$refs.track.scrollBy({ left: 300, behavior: 'smooth' })"
    >
      ▶
    </button>

    {% for block in section.blocks %}
      {% if block.type == 'carousel_item' %}
        <div class="b-carousel-item">
          <div class="b-card">
            <div class="b-card-header">
              <span class="b-ml-3 b-card-title">Title</span>
            </div>
            <div class="b-fixed-grid">
              <div class="b-grid b-p-2">
                <div class="b-cell">
                  <img src="https://placehold.co/400x400" alt="">
                </div>
                <div class="b-cell">
                  <img src="https://placehold.co/400x400" alt="">
                </div>
                <div class="b-cell">
                  <img src="https://placehold.co/400x400" alt="">
                </div>
                <div class="b-cell">
                  <img src="https://placehold.co/400x400" alt="">
                </div>
              </div>
            </div>
          </div>
        </div>
      {% endif %}
      {% if block.type == 'article' %}
        <div class="b-carousel-item">
          <div class="b-card">
            <header class="b-card-header">
              <p class="b-card-header-title b-is-capitalized b-title">{{ block.settings.article.title }}</p>
            </header>
            <div class="b-card-image">
              <figure class="b-image">
                {{
                  block.settings.article.image
                  | image_url: height: 800, pad_color: 'ffffff'
                  | image_tag:
                    widths: '50, 100,150, 200, 250, 300, 350, 400, 450, 500, 550, 600',
                    preload: block.settings.priority
                }}
              </figure>
            </div>
            <div class="b-card-content">
              <div class="b-content">
                {{ block.settings.article.excerpt | truncatewords: '20', '...' }}
              </div>
            </div>
            <footer class="b-card-footer">
              <a href="{{ block.settings.article.url }}" class="b-card-footer-item b-button b-is-link b-is-ghost">
                Read more
              </a>
            </footer>
          </div>
        </div>
      {% elsif block.type == 'collection' %}
        <div class="b-carousel-item">
          <div class="b-card">
            <header class="b-card-header">
              <p class="b-card-header-title b-is-capitalized b-title">{{ block.settings.collection.title }}</p>
            </header>
            <div class="b-card-image">
              <figure class="b-image">
                {{
                  block.settings.collection.featured_image
                  | image_url: height: 800, pad_color: 'ffffff'
                  | image_tag:
                    widths: '50, 100,150, 200, 250, 300, 350, 400, 450, 500, 550, 600',
                    preload: block.settings.priority
                }}
              </figure>
            </div>
            <div class="b-card-content">
              <div class="b-content">
                {{ block.settings.article.excerpt | truncatewords: '20', '...' }}
              </div>
            </div>
            <footer class="b-card-footer">
              <a href="{{ block.settings.article.url }}" class="b-card-footer-item b-button b-is-link b-is-ghost">
                Read more
              </a>
            </footer>
          </div>
        </div>
      {% endif %}
    {% endfor %}
  </div>
</section>

