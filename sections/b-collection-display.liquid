<style>
  /* ==========================================================
   b-carousel — PlayLoveToys / b-bulma-alpine component
   Scroll-snap horizontal, mobile-first, ultra minimal
   ========================================================== */

  .b-carousel {
    display: flex;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    gap: 1rem;
    padding-bottom: 0.25rem; /* espacio para evitar corte del shadow */
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;

    /* Ocultar scrollbar en Chrome/Safari */
    &::-webkit-scrollbar {
      display: none;
    }

    /* Cards dentro del carrusel */
    > .b-carousel-item {
      flex: 0 0 auto;
      scroll-snap-align: start;

      /* Permite usar cualquier card interna sin romper layout */
      width: 100%;

      /* Clamp de anchura para mobile (estilo tienda) */
      max-width: 80vw;
    }
  }

  /* Desktop: cards ligeramente más grandes */
  @media screen and (min-width: 1024px) {
    .b-carousel > .b-carousel-item {
      max-width: 320px;
      width: 100%;
    }
  }

  /* Opcional: flechas flotantes */
  .b-carousel-nav {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 20;
    cursor: pointer;
  }

  .b-carousel-nav.is-left {
    left: 0.25rem;
  }

  .b-carousel-nav.is-right {
    right: 0.25rem;
  }
</style>

{% assign products = section.settings.collection_id.products %}

<section class="b-section">
  <div
    class="b-carousel"
    x-data
    x-ref="track"
  >
    <!-- LEFT -->
    <button
      class="b-carousel-nav is-left"
      @click="$refs.track.scrollBy({ left: -300, behavior: 'smooth' })"
    >
      ◀
    </button>

    <!-- RIGHT -->
    <button
      class="b-carousel-nav is-right"
      @click="$refs.track.scrollBy({ left: 300, behavior: 'smooth' })"
    >
      ▶
    </button>

    {% for block in section.blocks %}
      {% if block.type == 'carousel_item' %}
        <div class="b-carousel-item">
          <div class="b-card">
            <div class="b-card-header">
              <span class="b-ml-3 b-card-title">Title</span>
            </div>
            <div class="b-fixed-grid">
              <div class="b-grid b-p-2">
                <div class="b-cell">
                  <img src="https://placehold.co/400x400" alt="">
                </div>
                <div class="b-cell">
                  <img src="https://placehold.co/400x400" alt="">
                </div>
                <div class="b-cell">
                  <img src="https://placehold.co/400x400" alt="">
                </div>
                <div class="b-cell">
                  <img src="https://placehold.co/400x400" alt="">
                </div>
                <div class="b-cell">
                  <img src="https://placehold.co/400x400" alt="">
                </div>
              </div>
            </div>
          </div>
        </div>
      {% endif %}
    {% endfor %}
  </div>
</section>

{% schema %}
{
  "name": "Bulma Collection Display",
  "settings": [
    {
      "type": "header",
      "content": "layout"
    },
    {
      "type": "collection",
      "id": "collection_id",
      "label": "Collection"
    }
  ],
  "blocks": [
    {
      "type": "carousel_item",
      "name": "Carousel Item"
    }
  ],
  "presets": [
    {
      "name": "Bulma Collection Display",
      "category": "Custom",
      "blocks": [
        {
          "type": "carousel_item"
        },
        {
          "type": "carousel_item"
        },
        {
          "type": "carousel_item"
        },
        {
          "type": "carousel_item"
        }
      ]
    }
  ]
}
{% endschema %}
