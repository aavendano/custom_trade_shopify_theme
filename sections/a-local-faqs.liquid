{% comment %}
  Local FAQs Section
  Purpose:
  - Add contextual FAQs to local landing pages
  - Reduce user friction (shipping, legality, privacy)
  - Link to future SEO programmatic FAQ pages
{% endcomment %}

<section class="b-section b-section--local-faqs">
  <div class="b-container">
    {% if section.settings.heading != blank %}
      <h2 class="b-title b-is-4">
        {{ section.settings.heading }}
      </h2>
    {% endif %}

    {% if section.settings.intro_text != blank %}
      <p class="b-content b-mb-5">
        {{ section.settings.intro_text }}
      </p>
    {% endif %}

    <div class="b-faq-list">
      {% for block in section.blocks %}
        <div class="b-faq-item">
          <h3 class="b-faq-question">
            {{ block.settings.question }}
          </h3>

          <div class="b-faq-answer">
            {{ block.settings.answer }}

            {% if block.settings.link_url != blank and block.settings.link_label != blank %}
              <p class="b-mt-2">
                <a href="{{ block.settings.link_url }}" class="b-link">
                  {{ block.settings.link_label }}
                </a>
              </p>
            {% endif %}
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Local FAQs (SEO)",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section heading",
      "default": "Buying adult toys online – common questions"
    },
    {
      "type": "textarea",
      "id": "intro_text",
      "label": "Intro text",
      "default": "These are some common questions customers ask before ordering adult toys online."
    }
  ],
  "blocks": [
    {
      "type": "faq",
      "name": "FAQ item",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question"
        },
        {
          "type": "richtext",
          "id": "answer",
          "label": "Answer"
        },
        {
          "type": "url",
          "id": "link_url",
          "label": "Optional link URL"
        },
        {
          "type": "text",
          "id": "link_label",
          "label": "Optional link label",
          "default": "Learn more"
        }
      ]
    }
  ],
  "max_blocks": 5,
  "presets": [
    {
      "name": "Local FAQs (SEO)",
      "category": "SEO"
    }
  ]
}
{% endschema %}
